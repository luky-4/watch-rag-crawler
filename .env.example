# ============================================
# Environment Variables - Example
# ============================================
# Copia questo file in .env e compila i valori
# cp .env.example .env

# Supabase (REQUIRED)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJxxx...
SUPABASE_TABLE=chunks

# OpenAI (REQUIRED for Supabase trigger)
# Nota: Questo viene settato in Supabase Settings → API → Custom Settings
# Nome: app.openai_api_key
OPENAI_API_KEY=sk-xxx...

# Crawler Settings (OPTIONAL)
MAX_PAGES=0          # 0 = unlimited
WORKERS=4            # Parallel workers
CRAWL_DELAY=1.0      # Seconds between requests

# Chunker Settings (OPTIONAL)
CHUNK_SIZE=300       # Target chunk size in tokens
CHUNK_OVERLAP=1      # Sentence overlap between chunks

# Upload Settings (OPTIONAL)
UPLOAD_BATCH_SIZE=100  # Batch size for Supabase upload
